{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Agro-Bots",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/RUN",  // Nombre de tu ejecutable
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build",  // Importante: compila antes de debuggear
            "miDebuggerPath": "/usr/bin/gdb"  // Ruta de gdb (ajusta si es necesario)
        }
    ]
}